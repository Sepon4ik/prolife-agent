generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ── Enums ──

enum CompanyType {
  DISTRIBUTOR
  PHARMACY_CHAIN
  RETAIL
  HYBRID
  UNKNOWN
}

enum Priority {
  A
  B
  C
}

enum CompanyStatus {
  RAW
  ENRICHED
  SCORED
  OUTREACH_SENT
  REPLIED
  INTERESTED
  NOT_INTERESTED
  HANDED_OFF
  DISQUALIFIED
}

enum EmailStatus {
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  REPLIED
  BOUNCED
  FAILED
}

enum OutreachType {
  INITIAL
  FOLLOW_UP_1
  FOLLOW_UP_2
  FOLLOW_UP_3
}

enum ScrapingSourceType {
  EXHIBITION
  LINKEDIN
  GOOGLE
  GOOGLE_MAPS
  DIRECTORY
  TRADE_REGISTRY
  REGULATORY
  NEWS_INTENT
  APOLLO
  WEBSITE
  MANUAL
}

enum GeoPriority {
  P1
  P2
  P3
}

// ── Models ──

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique

  // Kill switch: ALL outreach is blocked until explicitly enabled.
  // Email, LinkedIn, follow-ups — nothing goes out while this is false.
  outreachEnabled  Boolean @default(false)
  dailyRevealLimit Int     @default(30)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies        Company[]
  scrapingJobs     ScrapingJob[]
  users            ProlifeUser[]
  mailboxes        Mailbox[]
  linkedInAccounts LinkedInAccount[]
  topics           Topic[]
  newsItems        NewsItem[]
  alerts           Alert[]
  revealLogs       RevealLog[]
}

model ProlifeUser {
  id        String   @id @default(cuid())
  tenantId  String
  email     String   @unique
  name      String
  role      String   @default("member") // admin, sales_director, member
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  revealLogs RevealLog[]

  @@index([tenantId])
  @@map("prolife_user")
}

model Company {
  id          String        @id @default(cuid())
  tenantId    String
  name        String
  type        CompanyType   @default(UNKNOWN)
  country     String
  city        String?
  website     String?
  description String?
  priority    Priority      @default(C)
  score       Int           @default(0)
  status      CompanyStatus @default(RAW)
  geoPriority GeoPriority?

  // AI enrichment fields
  categories        String[]  @default([])
  estimatedRevenue   String?   // under_2m, 2m_10m, 10m_plus, unknown
  hasEcommerce       Boolean   @default(false)
  hasSalesTeam       Boolean   @default(false)
  hasMarketingTeam   Boolean   @default(false)
  hasMedReps         Boolean   @default(false)
  portfolioBrands    String[]  @default([])
  portfolioBrandInfo Json?     // { "BrandName": "Brief description", ... }
  pharmacyCount      Int?      // number of pharmacy outlets if chain
  activelySeekingBrands Boolean @default(false)

  // Source tracking
  source     ScrapingSourceType @default(MANUAL)
  sourceUrl  String?
  sourceExhibition String?

  contacts   Contact[]
  emails     Email[]
  newsItems  NewsItem[]
  revealLogs RevealLog[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, country, priority])
  @@index([tenantId, type])
  @@index([tenantId, geoPriority])
  @@unique([tenantId, name, country])
}

model Contact {
  id        String  @id @default(cuid())
  companyId String
  name      String
  title     String? // CEO, Sales Director, etc.
  email     String?
  phone     String?
  linkedin  String?
  photoUrl  String? // Avatar/photo URL from company website
  bio       String? // Brief professional bio
  languages String[] @default([]) // Languages spoken (for outreach personalization)
  isPrimary Boolean @default(false)

  // LinkedIn enrichment (from Apollo/PDL)
  linkedinHeadline  String?  // "VP Sales at Acme Corp"
  linkedinSeniority String?  // c_suite, vp, director, manager
  linkedinDepartment String? // sales, business_development, marketing

  // LinkedIn outreach tracking
  linkedinViewed     Boolean  @default(false)
  linkedinViewedAt   DateTime?
  linkedinConnected  Boolean  @default(false)
  linkedinConnectedAt DateTime?
  linkedinMessaged   Boolean  @default(false)
  linkedinMessagedAt DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  emails  Email[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([email])
  @@index([linkedin])
}

model Email {
  id         String       @id @default(cuid())
  companyId  String
  contactId  String?
  mailboxId  String?
  type       OutreachType
  status     EmailStatus  @default(QUEUED)
  subject    String
  body       String
  sentAt     DateTime?
  openedAt   DateTime?
  repliedAt  DateTime?
  replyBody  String?
  messageId  String?      // SES/Resend message ID
  variant    String?      // A/B test variant ("A", "B")

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id])
  mailbox Mailbox? @relation(fields: [mailboxId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([status])
  @@index([type, status])
  @@index([mailboxId])
}

model ScrapingJob {
  id         String             @id @default(cuid())
  tenantId   String
  sourceType ScrapingSourceType
  sourceUrl  String
  sourceName String?            // Exhibition name, etc.
  status     String             @default("pending") // pending, running, completed, failed
  totalFound Int                @default(0)
  totalNew   Int                @default(0)
  error      String?
  startedAt  DateTime?
  finishedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
}

model Mailbox {
  id        String   @id @default(cuid())
  tenantId  String
  email     String   // e.g. partnerships@prolife-global.net
  name      String   // Display name: "ProLife Partnership"
  domain    String   // prolife-global.net
  provider  String   @default("resend") // resend, ses
  apiKey    String?  // Provider-specific API key (encrypted in prod)
  isActive  Boolean  @default(true)
  isWarmedUp Boolean @default(false)

  // Daily sending limits
  dailyLimit    Int @default(40)
  sentToday     Int @default(0)
  sentTodayDate DateTime? // Reset counter when date changes

  // Health metrics (updated by webhook events)
  totalSent     Int @default(0)
  totalDelivered Int @default(0)
  totalOpened   Int @default(0)
  totalBounced  Int @default(0)
  totalReplied  Int @default(0)
  totalComplained Int @default(0)

  // DNS health (checked periodically)
  hasSPF    Boolean @default(false)
  hasDKIM   Boolean @default(false)
  hasDMARC  Boolean @default(false)
  lastDnsCheck DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  emails Email[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, email])
  @@index([tenantId, isActive])
}

model LinkedInAccount {
  id          String   @id @default(cuid())
  tenantId    String
  email       String   // LinkedIn login email
  name        String   // Display name
  profileUrl  String?  // LinkedIn profile URL
  provider    String   @default("unipile") // unipile, expandi
  isActive    Boolean  @default(true)
  isWarmedUp  Boolean  @default(false)

  tenant  Tenant @relation(fields: [tenantId], references: [id])
  actions LinkedInAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, email])
  @@index([tenantId, isActive])
}

model LinkedInAction {
  id               String   @id @default(cuid())
  accountId        String
  actionType       String   // profile_view, connection_request, message, inmail
  targetContactId  String
  metadata         Json     @default("{}")
  performedAt      DateTime @default(now())

  account LinkedInAccount @relation(fields: [accountId], references: [id])

  createdAt DateTime @default(now())

  @@index([accountId, actionType, performedAt])
  @@index([targetContactId])
}

model WebhookEvent {
  id         String   @id @default(cuid())
  externalId String   @unique
  type       String
  payload    Json
  processedAt DateTime

  createdAt DateTime @default(now())
}

// ── Intel: Industry News Intelligence ──

enum NewsCategory {
  CONTRACT        // New distribution deal, partnership
  EXPANSION       // Company enters new market
  REGULATORY      // Regulatory approval, policy change
  MA_FUNDING      // Merger, acquisition, funding round
  LEADERSHIP      // New executive appointed
  PRODUCT_LAUNCH  // New product or brand launched
  TENDER          // Government tender, procurement
  EVENT           // Exhibition, conference
  GENERAL         // Other industry news
}

model Topic {
  id        String   @id @default(cuid())
  tenantId  String
  name      String   // "Indonesia Pharma", "Supplement Distribution"
  keywords  String[] // ["pharma distributor indonesia", "supplement import"]
  countries String[] @default([]) // Filter by country
  isActive  Boolean  @default(true)

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  newsItems NewsItem[]
  alerts    Alert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
}

model NewsItem {
  id          String       @id @default(cuid())
  tenantId    String
  topicId     String?
  url         String       @unique // Deduplicate by URL
  title       String
  source      String       // "Google News", "PharmaBoardroom", etc.
  publishedAt DateTime?
  category    NewsCategory @default(GENERAL)

  // Full content (scraped from source)
  fullContent       String?  // Extracted article text (Readability)
  translatedContent String?  // Russian translation of full content (Claude)
  translatedTitle   String?  // Russian translation of title
  translatedSummary String?  // Russian translation of summary
  imageUrl          String?  // OG image / preview thumbnail

  // AI-generated fields
  summary     String?      // 2-3 sentence AI summary
  entities    String[]     @default([]) // Company names mentioned
  countries   String[]     @default([]) // Countries mentioned
  sentiment   String?      // positive, negative, neutral
  relevanceScore Int       @default(0) // 0-100, how relevant to client's niche

  // Link to existing companies in our DB
  companyId   String?      // If we matched a company

  // Engagement scoring (self-learning)
  engagementScore Int      @default(0)  // Accumulated: like +10, bookmark +5, click +1, dismiss -5
  isBookmarked    Boolean  @default(false)
  isDismissed     Boolean  @default(false)
  clickCount      Int      @default(0)

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  topic   Topic?   @relation(fields: [topicId], references: [id])
  company Company? @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([tenantId, category])
  @@index([tenantId, createdAt])
  @@index([companyId])
  @@index([relevanceScore])
  @@index([engagementScore])
}

model Alert {
  id        String   @id @default(cuid())
  tenantId  String
  topicId   String?
  name      String   // "High-relevance pharma news"

  // Trigger conditions
  minRelevance  Int      @default(70) // Only alert if relevanceScore >= this
  categories    String[] @default([]) // Filter by NewsCategory (empty = all)
  countries     String[] @default([]) // Filter by country (empty = all)

  // Delivery
  channel   String   @default("email") // email, telegram, slack, webhook
  target    String   // email address, chat ID, webhook URL
  isActive  Boolean  @default(true)

  // Tracking
  lastTriggeredAt DateTime?
  triggerCount    Int @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id])
  topic  Topic? @relation(fields: [topicId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, isActive])
}

// ── Data Protection: Reveal Tracking ──

model RevealLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  companyId String
  contactId String?  // null = company-level reveal
  createdAt DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  user    ProlifeUser @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@index([tenantId, userId, createdAt])
  @@index([companyId])
}

// ── Intel: Feed Health Monitoring ──

model FeedHealthLog {
  id             String   @id @default(cuid())
  feedUrl        String
  feedName       String
  status         String   // success, fail, timeout
  itemCount      Int      @default(0)
  errorMessage   String?
  responseTimeMs Int?
  collectedAt    DateTime @default(now())

  @@index([feedUrl, collectedAt])
  @@index([collectedAt])
}

// ── Auth ──
// better-auth tables (user, session, account, verification) are managed
// directly by better-auth via raw pg — NOT in this Prisma schema.
// See packages/auth/src/index.ts for config.
