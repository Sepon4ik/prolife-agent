{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env", "**/.env.local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "type-check": {
      "outputs": []
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate:deploy": {
      "cache": false,
      "inputs": ["prisma/**"]
    },
    "db:push": {
      "cache": false,
      "inputs": ["prisma/**"]
    }
  }
}
